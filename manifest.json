{
  "manifest_version": 3,
  "name": "Advanced Full Page Screenshot Tool",
  "version": "1.2",
  "permissions": ["tabs", "scripting", "activeTab", "downloads", "storage", "windows", "clipboardWrite"],
  "host_permissions": ["https://api.imgbb.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "commands": {
    "start-capture": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Start capture"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}